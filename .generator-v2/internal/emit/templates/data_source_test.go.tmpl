package test

import (
	"context"
{{- if .UseUniq }}
	"fmt"
	"strings"
{{- end }}
	"testing"

	"github.com/hashicorp/terraform-plugin-testing/helper/resource"
)

// {{ .FuncName }} is a generated scaffold. It needs a recorded cassette to pass
// in replay mode:
//  1. Complete {{ .ConfigFunc }} below: add the resource(s) that seed the data
//     this data source reads, and set the lookup/filter value(s).
//  2. Record the cassette: RECORD=true make testacc TESTARGS='-run {{ .FuncName }}'
//  3. Review {{ .CassettePath }} (and its .freeze), then commit them so the test
//     runs in replay mode.
func {{ .FuncName }}(t *testing.T) {
	t.Parallel()
{{- if .UseUniq }}
	ctx, _, accProviders := testAccFrameworkMuxProviders(context.Background(), t)
	uniq := strings.ToLower(uniqueEntityName(ctx, t))
{{- else }}
	_, _, accProviders := testAccFrameworkMuxProviders(context.Background(), t)
{{- end }}

	resource.Test(t, resource.TestCase{
		PreCheck:                 func() { testAccPreCheck(t) },
		ProtoV6ProviderFactories: accProviders,
		Steps: []resource.TestStep{
			{
				Config: {{ .ConfigFunc }}({{ if .UseUniq }}uniq{{ end }}),
				Check: resource.ComposeTestCheckFunc(
					resource.TestCheckResourceAttrSet("data.{{ .ResourceType }}.foo", "id"),
{{- if and .Plural .CollectionKey }}
					resource.TestCheckResourceAttrSet("data.{{ .ResourceType }}.foo", "{{ .CollectionKey }}.#"),
{{- end }}
					// TODO(tfgen): assert specific attributes once the cassette is recorded.
				),
			},
		},
	})
}

func {{ .ConfigFunc }}({{ if .UseUniq }}uniq string{{ end }}) string {
{{- if .UseUniq }}
	return fmt.Sprintf(`{{ .ConfigBody }}`, uniq)
{{- else }}
	return `{{ .ConfigBody }}`
{{- end }}
}
